# ============================================================
# SHIELD Platform — Environment Variables (.env.local)
# ============================================================
# Copy this file to .env.local and fill in your values.

# --- PostgreSQL (Docker) ---
DATABASE_URL=postgresql://shield:shieldpass@localhost:5432/shield_marketplace

# --- JWT ---
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cybersec_marketplace
MONGODB_DB_NAME=cybersec_marketplace

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email (Gmail) ---
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# --- Shield Internal & Integrations ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SECRET=your_internal_secret_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# --- Moderator Seed Account ---
# Used by: npx ts-node --project tsconfig.server.json prisma/seed-moderator.ts
MODERATOR_EMAIL=mod@shield.local
MODERATOR_PASSWORD=YourStrongPassword123!
